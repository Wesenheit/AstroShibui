---
import BaseLayout from './BaseLayout.astro';

const { title, date, pageHeader } = Astro.props.frontmatter;

const formattedDate = date ? new Date(date).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : null;
---
<BaseLayout title={title} headerSubtitle={pageHeader} date={date}>
  <div class="prose">
    <slot />
  </div>
</BaseLayout>
