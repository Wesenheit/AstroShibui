---
import BaseLayout from './BaseLayout.astro';

const { title, date, suptitle,long_title, show_title = true} = Astro.props.frontmatter;

const formattedDate = date ? new Date(date).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : null;
---
<BaseLayout title={title} suptitle={suptitle} date={date}>
{show_title && (
  <>
    <h2 class="text-xl font-medium tracking-tight">{long_title}</h2>
    <br />
  </>
)}
  <div class="prose">
    <slot />
  </div>
</BaseLayout>

