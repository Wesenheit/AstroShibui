---
interface Props {
  title?: string;
}
const { title = "" } = Astro.props;
---
<header class="border-b border-slate-200">
  <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
    <div>
      <a href="/" class="text-xl font-medium tracking-tight">/wesenheit/{title}</a>
    </div>
    <nav class="space-x-4 text-sm">
      <a href="/research" class="hover:underline">Research</a>
      <a href="/publications" class="hover:underline">Publications</a>
      <a href="/cv" class="hover:underline">CV</a>
      <a href="/blog" class="hover:underline">Notes</a>
    </nav>
  </div>
</header>
